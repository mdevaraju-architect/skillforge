# CODEOWNERS
# Automatically requests review from the listed owners for matching paths.

# Default: all PRs require review from a maintainer
*                                    @skillforge-maintainers

# Governance files require project lead
/governance/                         @skillforge-maintainers
/governance/compliance-matrix.md     @skillforge-maintainers

# Plugin code requires security review — these directly access live orgs
/plugins/                            @skillforge-maintainers
/plugins/_shared/                    @skillforge-maintainers

# Skill promotion to 'reviewed' requires 2 maintainers (enforced here)
/skills/**/skill-manifest.json       @skillforge-maintainers

# CI workflow changes require project lead
/.github/workflows/                  @skillforge-maintainers
